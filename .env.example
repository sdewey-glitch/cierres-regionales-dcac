# Cierres Regionales - Environment Variables Template
# Copy this file to .env and fill in the values.
# Do not commit the actual .env file to Git.

# Vercel Blob Storage Token (for file uploads if used)
BLOB_READ_WRITE_TOKEN="your_vercel_blob_rw_token_here"

# Cron & Scheduler Secrets
CRON_SECRET="your_cron_secret_here"

# Metabase Integration
METABASE_API_KEY="your_metabase_api_key_here"
METABASE_URL="https://metabase.dcac.ar"
METABASE_USERNAME="your_metabase_user"
METABASE_PASSWORD="your_metabase_password"
METABASE2_URL="https://metabase.dcac.ar"
METABASE2_USERNAME="your_metabase_user"
METABASE2_PASSWORD="your_metabase_password"

# Metabase Card IDs
METABASE_STATUS_CARD_ID=0
METABASE_KPI_CARD_ID=0
METABASE_CONCRETADAS_CARD_ID=0
METABASE_NO_CONC_CARD_ID=0
METABASE_TOP_COM_CARD_ID=0

# Google OAuth Configuration
GOOGLE_CLIENT_ID="your_google_client_id_here"
GOOGLE_CLIENT_SECRET="your_google_client_secret_here"

# Resend API Key (for emails)
RESEND_API_KEY="your_resend_api_key_here"

# NextAuth Configuration
NEXTAUTH_SECRET="your_nextauth_secret_here"
NEXTAUTH_URL="http://localhost:3000"

# Google Service Account Credentials
Google_mail="your-service-account@iam.gserviceaccount.com"
Google_key="-----BEGIN PRIVATE KEY-----\nyour_private_key_here\n-----END PRIVATE KEY-----\n"

# Google Sheets Spreadsheet IDs
TARGET_SPREADSHEET_ID="your_spreadsheet_id_here"
SOURCE_SPREADSHEET_ID="your_spreadsheet_id_here"
HUB_SPREADSHEET_ID="your_spreadsheet_id_here"
HUB_CONFIGURACIONES_ID="your_spreadsheet_id_here"
HUB_GASTOS_ID="your_spreadsheet_id_here"
HUB_CIERRES_ID="your_spreadsheet_id_here"
HUB_TABLERO_ID="your_spreadsheet_id_here"
HUB_HISTORIAL_ID="your_spreadsheet_id_here"
MASTER_ROSTER_ID="your_master_roster_spreadsheet_id"
MENDEL_SPREADSHEET_ID="your_mendel_spreadsheet_id"
CIERRES_ROOT_FOLDER_ID="your_drive_cierres_root_folder_id"

# Google Apps Script Email URL
APPS_SCRIPT_MAIL_URL="https://script.google.com/macros/s/.../exec"

# Other Settings
MAGIC_LINK_TEST_EMAIL="sdewey@decampoacampo.com"
RIO4_USERS="{\"Rio4to\":\"DCAC2026\"}"
NX_DAEMON="false"
TURBO_CACHE="remote:rw"
TURBO_DOWNLOAD_LOCAL_ENABLED="true"
TURBO_REMOTE_ONLY="true"
TURBO_RUN_SUMMARY="true"
VERCEL="1"
VERCEL_ENV="development"
VERCEL_TARGET_ENV="development"
