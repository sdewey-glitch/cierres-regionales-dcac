  "compilerOptions": {
    "target": "es2022",
    "module": "commonjs",
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "strict": true,
    "skipLibCheck": true
  },
  "exclude": [
    "frontend",
    "check_*.ts",
    "compare_*.ts",
    "rebuild_*.ts",
    "test_*.ts",
    "inspect_*.ts"
  ]
}
